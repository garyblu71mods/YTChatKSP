# EditorConfig is awesome: https://EditorConfig.org

# top-most EditorConfig file
root = true

# All files
[*]
charset = utf-8
insert_final_newline = true
trim_trailing_whitespace = true

# C# files
[*.cs]
indent_size = 4
indent_style = space
max_line_length = 120

# Markdown files
[*.md]
max_line_length = off

# JSON files
[*.json]
indent_size = 2
indent_style = space

# YAML files
[*.{yml,yaml}]
indent_size = 2
indent_style = space

# XML files
[*.{xml,csproj,resx}]
indent_size = 2
indent_style = space
